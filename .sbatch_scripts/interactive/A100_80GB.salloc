# Interactive allocation for A100 80GB GPU
# This file contains the salloc command for interactive sessions
# After the node is allocated, export thread caps before torchrun, e.g.:
#   export OMP_NUM_THREADS=1 MKL_NUM_THREADS=1 OPENBLAS_NUM_THREADS=1

salloc --gres=gpu:a100:1 --partition=a100 --constraint=a100_80 --cpus-per-task=16 --time=04:00:00 --job-name=U_it_A180 --mail-user=alberto1.rota@polimi.it --mail-type=ALL